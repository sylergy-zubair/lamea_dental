# WordPress CMS endpoint (set after Lightsail instance is provisioned)
WP_GRAPHQL_ENDPOINT=https://lamea-cms.lameadental.co.uk/graphql

# ISR revalidation secret (any random string, e.g. openssl rand -hex 32)
REVALIDATE_SECRET=change-me-to-a-random-string

# Online Consultation — Calendly booking link for evening slots
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/azubair64/30min

# Cloudflare R2 — photo uploads & lead storage (S3-compatible API)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=ld-consuntation-img
# Public URL for serving uploaded images (R2.dev subdomain or custom domain)
R2_PUBLIC_URL=
